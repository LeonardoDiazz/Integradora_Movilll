<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Fila 1: N° Inventario (teal) + Nombre + badges -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvInvNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="N° INV"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#0D9488"/>

                <TextView
                    android:id="@+id/tvEquipName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#111827"/>
            </LinearLayout>

            <!-- Badge ESTADO -->
            <TextView
                android:id="@+id/tvBadgeEstado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:text="Activo"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_badge_green"
                android:textColor="#065F46"/>

            <!-- Badge CONDICIÓN -->
            <TextView
                android:id="@+id/tvBadgeCond"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:text="Disponible"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_badge_green"
                android:textColor="#065F46"/>
        </LinearLayout>

        <!-- Fila 2: Tipo | Acceso -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TIPO"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="#9CA3AF"
                    android:layout_marginBottom="2dp"/>
                <TextView
                    android:id="@+id/tvCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="13sp"
                    android:textColor="#374151"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACCESO"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="#9CA3AF"
                    android:layout_marginBottom="2dp"/>
                <TextView
                    android:id="@+id/tvAccess"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="13sp"
                    android:textColor="#374151"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DESCRIPCIÓN"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="#9CA3AF"
                    android:layout_marginBottom="2dp"/>
                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="13sp"
                    android:textColor="#374151"
                    android:maxLines="1"
                    android:ellipsize="end"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Separador -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F3F4F6"
            android:layout_marginBottom="10dp"/>

        <!-- Botones de acción -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <ImageButton
                android:id="@+id/btnView"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_icon_btn"
                android:src="@drawable/ic_eye"
                android:padding="6dp"
                android:contentDescription="Ver"/>

            <ImageButton
                android:id="@+id/btnEdit"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_icon_btn_orange"
                android:src="@drawable/ic_edit"
                android:padding="6dp"
                android:contentDescription="Editar"/>

            <ImageButton
                android:id="@+id/btnHistory"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_icon_btn_purple"
                android:src="@drawable/ic_history"
                android:padding="6dp"
                android:contentDescription="Historial"/>

            <ImageButton
                android:id="@+id/btnToggle"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_icon_btn_red"
                android:src="@drawable/ic_power"
                android:padding="6dp"
                android:contentDescription="Cambiar estado"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
