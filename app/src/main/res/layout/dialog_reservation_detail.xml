<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Fila 1: ID | Estado -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="10dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:layout_marginEnd="6dp"
            android:orientation="vertical" android:padding="12dp"
            android:background="@drawable/bg_detail_card">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ID" android:textSize="11sp" android:textColor="#6B7280"
                android:layout_marginBottom="4dp"/>
            <TextView android:id="@+id/tvDetailId"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textSize="14sp" android:textStyle="bold"
                android:textColor="#111827"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:padding="12dp"
            android:background="@drawable/bg_detail_card">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ESTADO" android:textSize="11sp" android:textColor="#6B7280"
                android:layout_marginBottom="4dp"/>
            <TextView android:id="@+id/tvDetailStatus"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textSize="14sp" android:textStyle="bold"
                android:textColor="#111827"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Fila 2: Recurso | Tipo -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="10dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:layout_marginEnd="6dp"
            android:orientation="vertical" android:padding="12dp"
            android:background="@drawable/bg_detail_card">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="RECURSO" android:textSize="11sp" android:textColor="#6B7280"
                android:layout_marginBottom="4dp"/>
            <TextView android:id="@+id/tvDetailResource"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textSize="14sp" android:textStyle="bold"
                android:textColor="#111827"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:padding="12dp"
            android:background="@drawable/bg_detail_card">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="TIPO" android:textSize="11sp" android:textColor="#6B7280"
                android:layout_marginBottom="4dp"/>
            <TextView android:id="@+id/tvDetailType"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textSize="14sp" android:textStyle="bold"
                android:textColor="#111827"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Fila 3: Fecha Inicio | Hora Inicio -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="10dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:layout_marginEnd="6dp"
            android:orientation="vertical" android:padding="12dp"
            android:background="@drawable/bg_detail_card">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="FECHA INICIO" android:textSize="11sp" android:textColor="#6B7280"
                android:layout_marginBottom="4dp"/>
            <TextView android:id="@+id/tvDetailDate"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textSize="14sp" android:textStyle="bold"
                android:textColor="#111827"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:padding="12dp"
            android:background="@drawable/bg_detail_card">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="HORA INICIO" android:textSize="11sp" android:textColor="#6B7280"
                android:layout_marginBottom="4dp"/>
            <TextView android:id="@+id/tvDetailStartTime"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textSize="14sp" android:textStyle="bold"
                android:textColor="#111827"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Fila 4: Fecha Devolución | Hora Devolución -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="10dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:layout_marginEnd="6dp"
            android:orientation="vertical" android:padding="12dp"
            android:background="@drawable/bg_detail_card">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="FECHA DEVOLUCIÓN" android:textSize="11sp" android:textColor="#6B7280"
                android:layout_marginBottom="4dp"/>
            <TextView android:id="@+id/tvDetailEndDate"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textSize="14sp" android:textStyle="bold"
                android:textColor="#111827"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:padding="12dp"
            android:background="@drawable/bg_detail_card">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="HORA DEVOLUCIÓN" android:textSize="11sp" android:textColor="#6B7280"
                android:layout_marginBottom="4dp"/>
            <TextView android:id="@+id/tvDetailEndTime"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textSize="14sp" android:textStyle="bold"
                android:textColor="#111827"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Propósito (ancho completo) -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="12dp"
        android:background="@drawable/bg_detail_card">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="PROPÓSITO" android:textSize="11sp" android:textColor="#6B7280"
            android:layout_marginBottom="4dp"/>
        <TextView android:id="@+id/tvDetailPurpose"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="—" android:textSize="14sp" android:textStyle="bold"
            android:textColor="#111827"/>
    </LinearLayout>

    <!-- Comentario admin (visible solo si existe) -->
    <LinearLayout android:id="@+id/layoutAdminComment"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="12dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_badge_red"
        android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="COMENTARIO ADMIN" android:textSize="11sp" android:textColor="#991B1B"
            android:layout_marginBottom="4dp"/>
        <TextView android:id="@+id/tvDetailAdminComment"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="—" android:textSize="13sp" android:textColor="#7F1D1D"/>
    </LinearLayout>

</LinearLayout>
