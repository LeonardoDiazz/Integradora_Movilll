<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Fila 1: ID + RECURSO + badge ESTADO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#1"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#6B7280"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvResourceName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Recurso"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1D4ED8"/>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:text="Pendiente"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_badge_yellow"
                android:textColor="#92400E"/>
        </LinearLayout>

        <!-- Fila 2: TIPO | FECHA INICIO | HORARIO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="TIPO" android:textSize="9sp" android:textStyle="bold"
                    android:textColor="#9CA3AF" android:layout_marginBottom="2dp"/>
                <TextView android:id="@+id/tvType"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textSize="13sp" android:textColor="#374151"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="FECHA INICIO" android:textSize="9sp" android:textStyle="bold"
                    android:textColor="#9CA3AF" android:layout_marginBottom="2dp"/>
                <TextView android:id="@+id/tvDate"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textSize="13sp" android:textColor="#374151"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="HORARIO" android:textSize="9sp" android:textStyle="bold"
                    android:textColor="#9CA3AF" android:layout_marginBottom="2dp"/>
                <TextView android:id="@+id/tvSchedule"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textSize="13sp" android:textColor="#374151"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Separador -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#F3F4F6" android:layout_marginBottom="10dp"/>

        <!-- Botones de acción -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <!-- Ver -->
            <ImageButton
                android:id="@+id/btnView"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_icon_btn"
                android:src="@drawable/ic_eye"
                android:padding="6dp"
                android:contentDescription="Ver"/>

            <!-- Editar (solo en PENDIENTE) -->
            <ImageButton
                android:id="@+id/btnEdit"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_icon_btn_orange"
                android:src="@drawable/ic_edit"
                android:padding="6dp"
                android:contentDescription="Editar"/>

            <!-- Cancelar (solo en PENDIENTE) -->
            <ImageButton
                android:id="@+id/btnCancel"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_icon_btn_red"
                android:src="@drawable/ic_power"
                android:padding="6dp"
                android:contentDescription="Cancelar"/>

            <!-- Motivo rechazo (solo en RECHAZADA) -->
            <ImageButton
                android:id="@+id/btnRejection"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_icon_btn_orange"
                android:src="@drawable/ic_warning"
                android:padding="6dp"
                android:contentDescription="Ver motivo"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
