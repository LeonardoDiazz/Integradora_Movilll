<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gray_light">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        android:background="@color/white">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Reservas"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Control de solicitudes de espacios físicos y equipamiento institucional."
                android:textSize="13sp"
                android:textColor="@color/gray_text"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddReservation"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="+ Nueva"
            android:textSize="12sp"
            android:backgroundTint="@color/green_primary"
            style="@style/Widget.MaterialComponents.Button"/>

    </LinearLayout>

    <!-- Filtros -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp"
        android:background="@color/white"
        android:elevation="4dp">

        <!-- Fila 1: ESTATUS y DISPONIBILIDAD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <!-- ESTATUS DE SOLICITUD -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="ESTATUS DE SOLICITUD" android:textSize="9sp" android:textStyle="bold"
                    android:textColor="@color/gray_text" android:layout_marginBottom="2dp"/>
                <Spinner android:id="@+id/spinnerFilter"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/bg_filter_spinner"/>
            </LinearLayout>

            <!-- DISPONIBILIDAD -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="DISPONIBILIDAD" android:textSize="9sp" android:textStyle="bold"
                    android:textColor="@color/gray_text" android:layout_marginBottom="2dp"/>
                <Spinner android:id="@+id/spinnerTipo"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/bg_filter_spinner"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Fila 2: SOLICITANTE + botón limpiar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- SOLICITANTE -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="SOLICITANTE" android:textSize="9sp" android:textStyle="bold"
                    android:textColor="@color/gray_text" android:layout_marginBottom="2dp"/>
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSearch"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="Nombre del usuario..."
                        android:inputType="text"
                        android:textSize="13sp"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- LIMPIAR -->
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text=" " android:textSize="9sp" android:layout_marginBottom="2dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClearFilters"
                    android:layout_width="48dp" android:layout_height="48dp"
                    android:text="↺" android:textSize="14sp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="8dp"
        android:background="@color/white">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPrev"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="&lt; Anterior"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/tvPage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pág 1"
            android:textSize="13sp"
            android:layout_marginHorizontal="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Siguiente &gt;"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textSize="12sp"/>
    </LinearLayout>

</LinearLayout>
