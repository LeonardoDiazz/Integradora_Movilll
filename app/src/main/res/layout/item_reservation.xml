<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Fila 1: Solicitante + estatus de solicitud -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvRequester"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Solicitante"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#111827"/>

                <TextView
                    android:id="@+id/tvResourceName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="12sp"
                    android:textColor="#6B7280"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="PENDIENTE"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_badge_yellow"
                android:textColor="#92400E"/>
        </LinearLayout>

        <!-- Fila 2: Categoría + fecha -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tvCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:text="ESPACIO"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_badge_purple"
                android:textColor="#5B21B6"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Fecha"
                android:textColor="#6B7280"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Separador -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F3F4F6"
            android:layout_marginBottom="10dp"/>

        <!-- Botones de acción -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <!-- Ver detalle -->
            <ImageButton
                android:id="@+id/btnViewDetail"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_icon_btn"
                android:src="@drawable/ic_eye"
                android:padding="7dp"
                android:contentDescription="Ver detalle"/>

            <!-- Aprobar (solo PENDIENTE) -->
            <ImageButton
                android:id="@+id/btnApprove"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_icon_btn_green"
                android:src="@drawable/ic_check"
                android:padding="7dp"
                android:visibility="gone"
                android:contentDescription="Aprobar"/>

            <!-- Rechazar (solo PENDIENTE) -->
            <ImageButton
                android:id="@+id/btnReject"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_icon_btn_red"
                android:src="@drawable/ic_close"
                android:padding="7dp"
                android:visibility="gone"
                android:contentDescription="Rechazar"/>

            <!-- Registrar devolución (solo APROBADA) -->
            <ImageButton
                android:id="@+id/btnReturn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_icon_btn_purple"
                android:src="@drawable/ic_return"
                android:padding="7dp"
                android:visibility="gone"
                android:contentDescription="Registrar devolución"/>

            <!-- Editar (usuario) -->
            <ImageButton
                android:id="@+id/btnEditReservation"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_icon_btn_orange"
                android:src="@drawable/ic_edit"
                android:padding="7dp"
                android:visibility="gone"
                android:contentDescription="Editar"/>

            <!-- Ver motivo rechazo (usuario) -->
            <ImageButton
                android:id="@+id/btnViewRejection"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_icon_btn_gray"
                android:src="@drawable/ic_warning"
                android:padding="7dp"
                android:visibility="gone"
                android:contentDescription="Ver rechazo"/>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
